# Cible du proxy Next.js côté serveur (app/api/proxy/[...path]/route.ts)
BACKEND_URL=http://127.0.0.1:8000/api

# Utilisée côté client (redirections OAuth, appels directs affichés dans le navigateur)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── WebSocket temps réel (messagerie, notifications) ────────────────────────
# Dev local : laisser NEXT_PUBLIC_PUSHER_KEY vide → bascule automatique sur Reverb
# (voir src/lib/echo.ts). Ces valeurs doivent correspondre à REVERB_* dans
# vroom-backend/.env.
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# Production uniquement (laisser vide en dev local — doit correspondre à PUSHER_* côté backend)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1
