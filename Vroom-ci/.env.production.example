NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_URL=                      # URL Railway/Render ex: https://vroom-backend.railway.app/api
NEXT_PUBLIC_BACKEND_URL=          # même URL sans /api ex: https://vroom-backend.railway.app

# ── Pusher (WebSocket en production) ─────────────────────────────────────────
NEXT_PUBLIC_PUSHER_KEY=           # App Key depuis dashboard Pusher
NEXT_PUBLIC_PUSHER_CLUSTER=mt1    # cluster choisi sur Pusher

# ── Google OAuth (callback frontend) ─────────────────────────────────────────
