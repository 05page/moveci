APP_NAME=Vroom
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# URL du frontend Next.js — utilisée pour les redirections OAuth Google
FRONTEND_URL=http://localhost:3000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vroom
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_TOKEN_EXPIRATION=10080

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — SMTP fourni par l'hébergeur (Hostinger en prod). Resend est installé
# comme dépendance transitive mais n'est jamais utilisé, ne pas configurer RESEND_API_KEY.
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@vroom.example"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Google OAuth (login) + Google Calendar (RDV vendeur) ────────────────────
# Identifiants sur https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8000/api/auth/google/callback

# ── Google Gemini (auto-modération des annonces véhicule) ──────────────────
# Clé sur https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── WebSocket temps réel (messagerie, notifications) ────────────────────────
# Dev local : Reverb auto-hébergé (BROADCAST_CONNECTION=reverb ci-dessus).
# Production : Pusher managé (mettre BROADCAST_CONNECTION=pusher) — le frontend
# choisit automatiquement Reverb ou Pusher selon les variables NEXT_PUBLIC_*
# définies côté Vroom-ci (voir src/lib/echo.ts). Les deux jeux de clés doivent
# correspondre à ceux de Vroom-ci/.env.local.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Production uniquement (laisser vide en dev local)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
